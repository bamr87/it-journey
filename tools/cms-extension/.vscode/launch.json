{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (on it-journey)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/../..",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "compile"
    }
  ]
}
